<Window x:Class="ScreenshotSpirit.Views.CaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Normal"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        Cursor="Cross">
    <Canvas x:Name="RootCanvas" Background="Transparent">
        <Image x:Name="ScreenshotImage" Stretch="None" />
        <Path x:Name="OverlayPath" Fill="#80000000" />
        <Rectangle x:Name="SelectionRect" Stroke="White" StrokeThickness="2" Fill="Transparent" Visibility="Collapsed" />
        <Rectangle x:Name="HandleTop" Fill="White" Width="8" Height="8" Visibility="Collapsed" Cursor="SizeNS" />
        <Rectangle x:Name="HandleBottom" Fill="White" Width="8" Height="8" Visibility="Collapsed" Cursor="SizeNS" />
        <Rectangle x:Name="HandleLeft" Fill="White" Width="8" Height="8" Visibility="Collapsed" Cursor="SizeWE" />
        <Rectangle x:Name="HandleRight" Fill="White" Width="8" Height="8" Visibility="Collapsed" Cursor="SizeWE" />
        <Rectangle x:Name="HandleTL" Fill="White" Width="8" Height="8" Visibility="Collapsed" Cursor="SizeNWSE" />
        <Rectangle x:Name="HandleTR" Fill="White" Width="8" Height="8" Visibility="Collapsed" Cursor="SizeNESW" />
        <Rectangle x:Name="HandleBL" Fill="White" Width="8" Height="8" Visibility="Collapsed" Cursor="SizeNESW" />
        <Rectangle x:Name="HandleBR" Fill="White" Width="8" Height="8" Visibility="Collapsed" Cursor="SizeNWSE" />
        <Rectangle x:Name="SnapHighlight" Stroke="#FF0078D7" StrokeThickness="3" Fill="#220078D7" Visibility="Collapsed" />
        <StackPanel x:Name="ConfirmPanel" Orientation="Horizontal" Visibility="Collapsed">
            <Button x:Name="BtnConfirm" Content="✓ 确定" IsDefault="True" Width="80" Height="32" Margin="4" Foreground="White" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#FF0078D7" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button x:Name="BtnCancelCapture" Content="✕ 取消" IsCancel="True" Width="80" Height="32" Margin="4" Foreground="White" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#CC333333" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Canvas>
</Window>
