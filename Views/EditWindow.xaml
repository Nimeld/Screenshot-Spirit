<Window x:Class="ScreenshotSpirit.Views.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑截图"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Action buttons -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="8,4" BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnSettings" Content="设置" Width="80" Height="30" Margin="4,0" Click="BtnSettings_Click" />
                <Button x:Name="BtnSave" Content="保存 (Ctrl+S)" Width="130" Height="30" Margin="4,0" Click="BtnSave_Click" />
                <Button x:Name="BtnCopy" Content="复制 (Ctrl+C)" Width="130" Height="30" Margin="4,0" Click="BtnCopy_Click" />
                <Button x:Name="BtnCancel" Content="取消 (Esc)" Width="120" Height="30" Margin="4,0" Click="BtnCancel_Click" />
                <Separator Width="1" Background="#555" Margin="8,0" />
                <Button x:Name="BtnUndo" Content="撤销" Margin="2" Padding="8,2" Click="BtnUndo_Click" />
                <Button x:Name="BtnRedo" Content="重做" Margin="2" Padding="8,2" Click="BtnRedo_Click" />
            </StackPanel>
        </Border>

        <!-- Row 1: Tools -->
        <Border Grid.Row="1" Background="#2D2D2D" Padding="8,3" BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ToolRect" Content="矩形" GroupName="Tools" Margin="2" IsChecked="True" Checked="Tool_Checked" Style="{StaticResource ToolRadioStyle}" />
                <RadioButton x:Name="ToolCircle" Content="圆形" GroupName="Tools" Margin="2" Checked="Tool_Checked" Style="{StaticResource ToolRadioStyle}" />
                <RadioButton x:Name="ToolLine" Content="直线" GroupName="Tools" Margin="2" Checked="Tool_Checked" Style="{StaticResource ToolRadioStyle}" />
                <RadioButton x:Name="ToolCurve" Content="曲线" GroupName="Tools" Margin="2" Checked="Tool_Checked" Style="{StaticResource ToolRadioStyle}" />
                <RadioButton x:Name="ToolArrow" Content="箭头" GroupName="Tools" Margin="2" Checked="Tool_Checked" Style="{StaticResource ToolRadioStyle}" />
                <RadioButton x:Name="ToolMosaic" Content="马赛克" GroupName="Tools" Margin="2" Checked="Tool_Checked" Style="{StaticResource ToolRadioStyle}" />
                <RadioButton x:Name="ToolText" Content="文字" GroupName="Tools" Margin="2" Checked="Tool_Checked" Style="{StaticResource ToolRadioStyle}" />
            </StackPanel>
        </Border>

        <!-- Row 2: Color / Size / Font bar -->
        <Border Grid.Row="2" Background="#2D2D2D" Padding="8,2" BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="ColorLabel" Text="颜色:" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,6,0" />
                <Rectangle x:Name="ColorPreview" Width="24" Height="24" Fill="Red" Stroke="#FFF" StrokeThickness="1" Margin="2" />
                <Button x:Name="PickColorBtn" Content="取色" Margin="2" Padding="4,0" Click="BtnPickColor_Click" />
                <TextBlock x:Name="SizeLabel" Text="粗细:" Foreground="#AAA" VerticalAlignment="Center" Margin="12,0,6,0" /><TextBlock x:Name="BrushSizeLabel" Text="笔刷大小:" Foreground="#AAA" VerticalAlignment="Center" Margin="12,0,6,0" Visibility="Collapsed" />
                <Slider x:Name="SizeSlider" Minimum="1" Maximum="80" Value="35" Width="80" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ElementName=SizeSlider, Path=Value, StringFormat={}{0:F0}}" Foreground="#AAA" VerticalAlignment="Center" Margin="4,0,0,0" />
                <TextBlock x:Name="MosaicSizeLabel" Text="颗粒:" Foreground="#AAA" VerticalAlignment="Center" Margin="12,0,6,0" Visibility="Collapsed" />
                <Slider x:Name="MosaicSizeSlider" Minimum="4" Maximum="40" Value="10" Width="80" VerticalAlignment="Center" Visibility="Collapsed" />
                <TextBlock x:Name="MosaicSizeValue" Text="{Binding ElementName=MosaicSizeSlider, Path=Value, StringFormat={}{0:F0}}" Foreground="#AAA" VerticalAlignment="Center" Margin="4,0,0,0" Visibility="Collapsed" />
                <TextBlock x:Name="FontLabel" Text="字体:" Foreground="#AAA" VerticalAlignment="Center" Margin="12,0,4,0" Visibility="Collapsed" />
                <ComboBox x:Name="FontFamilyBox" Width="120" VerticalAlignment="Center" Visibility="Collapsed" SelectionChanged="FontFamilyBox_SelectionChanged">
                    <ComboBoxItem Content="微软雅黑" Tag="Microsoft YaHei" />
                    <ComboBoxItem Content="宋体" Tag="SimSun" />
                    <ComboBoxItem Content="黑体" Tag="SimHei" />
                    <ComboBoxItem Content="楷体" Tag="KaiTi" />
                    <ComboBoxItem Content="仿宋" Tag="FangSong" />
                    <ComboBoxItem Content="Arial" Tag="Arial" />
                    <ComboBoxItem Content="Consolas" Tag="Consolas" />
                </ComboBox>
                <ToggleButton x:Name="BtnBold" Content="B" Width="26" Height="22" FontWeight="Bold" Margin="6,0,0,0" Visibility="Collapsed" Click="BtnBold_Click" />
                <ToggleButton x:Name="BtnItalic" Content="I" Width="26" Height="22" FontStyle="Italic" Margin="2,0,0,0" Visibility="Collapsed" Click="BtnItalic_Click" />
                <ToggleButton x:Name="BtnUnderline" Width="26" Height="22" Margin="2,0,0,0" Visibility="Collapsed" Checked="BtnUnderline_Checked" Unchecked="BtnUnderline_Unchecked">
                    <ToggleButton.Content>
                        <TextBlock Text="U" TextDecorations="Underline" IsHitTestVisible="False" />
                    </ToggleButton.Content>
                </ToggleButton>
                <Button x:Name="BtnReset" Content="重置" Margin="12,0,0,0" Padding="8,2" Click="BtnReset_Click" />
            </StackPanel>
        </Border>

        <!-- Row 3: Canvas -->
        <Canvas Grid.Row="3" x:Name="CanvasContainer" ClipToBounds="True" Background="#2A2A2A">
            <Grid x:Name="CanvasGrid" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Image x:Name="SourceImage" Stretch="None" />
                <Canvas x:Name="MosaicCanvas" Background="Transparent" />
                <Canvas x:Name="DrawCanvas" Background="Transparent" />
                <InkCanvas x:Name="InkCanvas" Background="Transparent" Visibility="Collapsed" />
            </Grid>
        </Canvas>
    </Grid>
</Window>